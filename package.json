{
  "name": "family-ai-agent",
  "version": "1.0.0",
  "description": "Family AI assistant (WhatsApp automation disabled)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --test tests/*.test.js",
    "test:contacts": "node --test tests/contacts.test.js",
    "test:tasks": "node --test tests/tasks.test.js",
    "test:payments": "node --test tests/payments.test.js",
    "test:inbox": "node --test tests/inbox.test.js",
    "test:gmail": "node --test tests/gmail.test.js",
    "test:coverage": "c8 --include=lib/contacts.js --include=lib/contactsSchemas.js --include=lib/contactsRouter.js --include=lib/tasks.js --include=lib/tasksSchemas.js --include=lib/tasksRouter.js --include=lib/payments.js --include=lib/paymentsSchemas.js --include=lib/paymentsRouter.js --include=lib/inbox.js --include=lib/inboxSchemas.js --include=lib/inboxRouter.js --include=lib/inboxAnalysis.js --include=lib/inboxSync.js --check-coverage --lines 95 --functions 95 --branches 90 --statements 95 node --test tests/contacts.test.js tests/tasks.test.js tests/payments.test.js tests/inbox.test.js",
    "test:coverage:tasks": "c8 --include=lib/tasks.js --include=lib/tasksSchemas.js --include=lib/tasksRouter.js --check-coverage --lines 95 --functions 95 --branches 90 --statements 95 node --test tests/tasks.test.js",
    "test:coverage:payments": "c8 --include=lib/payments.js --include=lib/paymentsSchemas.js --include=lib/paymentsRouter.js --check-coverage --lines 95 --functions 95 --branches 90 --statements 95 node --test tests/payments.test.js",
    "test:coverage:inbox": "c8 --include=lib/inbox.js --include=lib/inboxSchemas.js --include=lib/inboxRouter.js --include=lib/inboxAnalysis.js --include=lib/inboxSync.js --check-coverage --lines 95 --functions 95 --branches 90 --statements 95 node --test tests/inbox.test.js",
    "test:coverage:gmail": "c8 --include=lib/gmail.js --include=lib/gmailRouter.js --include=lib/gmailClient.js --include=lib/tokenEncryption.js --check-coverage --lines 85 --functions 85 --branches 75 --statements 85 node --test tests/gmail.test.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "express": "^4.18.2",
    "googleapis": "^140.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "prisma": "6.19.3",
    "supertest": "^7.0.0"
  }
}
